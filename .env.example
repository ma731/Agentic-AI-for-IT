# Primary: Groq free tier (https://console.groq.com — free key, no card)
GROQ_API_KEY=your_groq_key_here

# Model string passed to init_chat_model. Default if unset: groq:llama-3.3-70b-versatile
# Offline fallback example (no network, needs `ollama serve`): ollama:llama3.1:8b
TOS_MODEL=groq:llama-3.3-70b-versatile
