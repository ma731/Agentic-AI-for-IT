# ============================================================================
# Model provider — SWAP ANY TIME (free tiers hit limits, so switching is expected)
# ----------------------------------------------------------------------------
# Two ways to choose a provider:
#   1) Set TOS_MODEL = "provider:model"  (forces a specific one), OR
#   2) Leave TOS_MODEL unset and just drop ONE key below — the app AUTO-DETECTS
#      the first provider whose key is present (priority: gemini → groq →
#      openrouter → openai → anthropic → mistral).
#
# To switch providers mid-project: change TOS_MODEL, or comment out one key and
# add another. Nothing else changes.
# ============================================================================

# Pick ONE (or more) — the active one is auto-detected if TOS_MODEL is unset:
GOOGLE_API_KEY=your_gemini_key_here          # https://aistudio.google.com/apikey  (free, no card)
# GROQ_API_KEY=your_groq_key_here            # https://console.groq.com            (free, fast)
# OPENROUTER_API_KEY=your_openrouter_key     # https://openrouter.ai/keys  ← ONE key, many FREE models (best for limits)
# OPENAI_API_KEY=your_openai_key             # paid
# ANTHROPIC_API_KEY=your_anthropic_key       # paid
# MISTRAL_API_KEY=your_mistral_key           # free tier

# Optional: force a specific provider:model (overrides auto-detect)
# TOS_MODEL=google_genai:gemini-2.5-flash            # balanced default
# TOS_MODEL=google_genai:gemini-2.5-flash-lite       # cheapest + highest free RPM
# TOS_MODEL=groq:llama-3.3-70b-versatile             # fast
# TOS_MODEL=openrouter:meta-llama/llama-3.3-70b-instruct:free   # free via OpenRouter
# TOS_MODEL=openrouter:deepseek/deepseek-chat-v3:free          # another free option
# TOS_MODEL=ollama:llama3.1:8b                        # local, no key (needs `ollama serve`)

# NOTE: a consumer "AI Pro/Plus/Ultra" chat subscription does NOT grant API access —
# any provider key above is an API key from its developer console.
