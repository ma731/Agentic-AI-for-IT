# Primary: Gemini — free API key at https://aistudio.google.com/apikey (no card, no subscription).
# NOTE: a consumer "Google AI Pro/Ultra" subscription does NOT grant API access — use a
# Google AI Studio API key here. Free tier is enough with the recorded-replay demo fallback.
GOOGLE_API_KEY=your_gemini_key_here

# Model string passed to init_chat_model. Default if unset: google_genai:gemini-2.5-flash
#   google_genai:gemini-2.5-flash        — balanced default (good tool-calling)
#   google_genai:gemini-2.5-flash-lite   — cheapest + highest free RPM (stretches the free tier)
TOS_MODEL=google_genai:gemini-2.5-flash

# Alternatives (optional):
#   GROQ_API_KEY=...    + TOS_MODEL=groq:llama-3.3-70b-versatile   (fast, free at console.groq.com)
#   ollama serve        + TOS_MODEL=ollama:llama3.1:8b            (offline, no network)
